# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL + TimescaleDB)
DATABASE_URL=postgresql://user:password@localhost:5432/energy_monitor

# Redis
REDIS_URL=redis://localhost:6379

# Firebase
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-firebase-client-email
FIREBASE_PRIVATE_KEY=your-firebase-private-key

# Emporia API
EMPORIA_API_BASE_URL=https://api.emporiaenergy.com

# SMA Sunny Portal
SMA_API_BASE_URL=https://www.sunnyportal.com/api/v1

# Logging
LOG_LEVEL=info
